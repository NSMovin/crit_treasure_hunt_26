# ─────────────────────────────────────────────────────────────────────────────
# .env.example — Treasure Hunt Live
#
# Copy this file to .env and fill in your values.
# Never commit .env to version control.
#
# For Vercel deployments: add these as Environment Variables in the
# Vercel project dashboard (Settings → Environment Variables).
# ─────────────────────────────────────────────────────────────────────────────

# ── Supabase ──────────────────────────────────────────────────────────────────
# Find both values in: Supabase Dashboard → Project Settings → API
# The anon key is intentionally public — security is enforced by Row-Level Security.
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key-here

# ── Admin ─────────────────────────────────────────────────────────────────────
# Passcode for the /admin.html dashboard. Keep the admin URL private.
# Use a strong, unique passcode — change this before every event.
VITE_ADMIN_PASSCODE=YourStrongPasscodeHere